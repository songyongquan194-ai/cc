[
  {
    "name": "Windows User Temp",
    "category": "sys_temp",
    "match": { "path_globs": ["%TEMP%\\*", "%TMP%\\*"], "min_age_days": 1 },
    "risk_level": "safe",
    "default_action": "clean",
    "delete_policy": "delete_children_only",
    "requires_app_closed": false,
    "explain": "用户临时文件，通常可重新生成，清理低风险。",
    "priority_class": 4
  },
  {
    "name": "Windows System Temp",
    "category": "sys_temp",
    "match": { "path_globs": ["C:\\Windows\\Temp\\*"], "min_age_days": 1 },
    "risk_level": "safe",
    "default_action": "clean",
    "delete_policy": "delete_children_only",
    "requires_app_closed": false,
    "explain": "系统临时文件，可清理。被占用的文件会自动跳过。",
    "priority_class": 4
  },
  {
    "name": "Thumbnail Cache",
    "category": "sys_thumbnail",
    "match": { "path_globs": ["%LOCALAPPDATA%\\Microsoft\\Windows\\Explorer\\thumbcache_*.db"] },
    "risk_level": "safe",
    "default_action": "clean",
    "delete_policy": "delete_self",
    "requires_app_closed": false,
    "explain": "缩略图缓存，清理后首次浏览文件夹会重新生成。",
    "priority_class": 4
  },
  {
    "name": "Crash Dumps",
    "category": "sys_crashdump",
    "match": { "path_globs": ["%LOCALAPPDATA%\\CrashDumps\\*", "C:\\Windows\\Minidump\\*"] },
    "risk_level": "safe",
    "default_action": "clean",
    "delete_policy": "delete_children_only",
    "requires_app_closed": false,
    "explain": "崩溃转储文件，用于事后诊断，一般可清理。",
    "priority_class": 4
  },
  {
    "name": "Windows Update Cache",
    "category": "sys_update_cache",
    "match": { "path_globs": ["C:\\Windows\\SoftwareDistribution\\Download\\*"] },
    "risk_level": "low",
    "default_action": "clean",
    "delete_policy": "delete_children_only",
    "requires_app_closed": false,
    "explain": "Windows 更新下载缓存，清理前建议先暂停更新服务。",
    "priority_class": 3
  },
