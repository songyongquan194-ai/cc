  },
  {
    "name": "Docker WSL vdisk (protected)",
    "category": "vm_wsl",
    "match": { "path_globs": ["%LOCALAPPDATA%\\Docker\\wsl\\*\\ext4.vhdx", "%LOCALAPPDATA%\\Packages\\*\\LocalState\\ext4.vhdx"] },
    "risk_level": "high",
    "default_action": "none",
    "delete_policy": "none",
    "requires_app_closed": false,
